{
  "name": "routag-automation-suite",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint --ext .ts \"test/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint --fix --ext .ts \"test/**/*.ts\"",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "wdio": "wdio run ./wdio.conf.ts",
    "test:sender:auth:valid-login": "wdio run ./wdio.conf.ts --spec test/specs/sender/authentication/loginWithValidCredentials.test.ts",
    "test:sender:auth:invalid-login": "wdio run ./wdio.conf.ts --spec test/specs/sender/authentication/loginWithInvalidCredentials.test.ts",
    "test:sender:onboarding:sign-up": "wdio run ./wdio.conf.ts --spec test/specs/sender/onboarding/signUpSender.test.ts",
    "test:sender:delivery:broadcast-delivery": "wdio run ./wdio.conf.ts --spec test/specs/sender/delivery/createDeliveryBroadcast.test.ts",
    "test:sender:account-switching:switch-account-from-sender-to-courier": "wdio run ./wdio.conf.ts --spec test/specs/sender/accountSwitching/switchAccountFromSenderToCourier.test.ts",
    "test:courier:account-switching:switch-account-from-courier-to-sender": "wdio run ./wdio.conf.ts --spec test/specs/courier/accountSwitching/switchAccountFromCourierToSender.test.ts",
    "test:courier:auth:valid-login": "wdio run ./wdio.conf.ts --spec test/specs/courier/authentication/loginWithValidCredentials.test.ts",
    "test:courier:auth:invalid-login": "wdio run ./wdio.conf.ts --spec test/specs/courier/authentication/loginWithInvalidCredentials.test.ts",
    "test:courier:wallet:withdraw-funds": "wdio run ./wdio.conf.ts --spec test/specs/courier/wallet/withdrawFromCourierWallet.test.ts",
    "test:courier:wallet:withdraw-funds-invalid-pin": "wdio run ./wdio.conf.ts --spec test/specs/courier/wallet/withdrawFromCourierWalletWithInvalidPin.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@wdio/appium-service": "^9.25.0",
    "@wdio/cli": "^9.25.0",
    "@wdio/globals": "^9.23.0",
    "@wdio/local-runner": "^9.25.0",
    "@wdio/logger": "^9.18.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.25.0",
    "appium": "^3.2.2",
    "appium-uiautomator2-driver": "^7.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "expect-webdriverio": "^5.6.4",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "wdio-wait-for": "^3.1.1"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}
